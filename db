CREATE OR REPLACE FUNCTION public.handle_new_user()
RETURNS TRIGGER AS $$
BEGIN
    -- Create default tanks
    INSERT INTO public.tanks (user_id, fuel_type, name, current_stock, capacity)
    VALUES
