CREATE TRIGGER update_cash_adv_updated      BEFORE UPDATE ON public.cash_advances       FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();
CREATE TRIGGER update_mobil_prod_updated    BEFORE UPDATE ON public.mobil_products      FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();


