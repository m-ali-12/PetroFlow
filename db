-- ================================================================
-- STEP 3: CORE TABLES
-- ================================================================

-- ── SETTINGS ──────────────────────────────────────────────────
CREATE TABLE public.settings (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    petrol_price    NUMERIC(10,2)  DEFAULT 276.50,
    diesel_price    NUMERIC(10,2)  DEFAULT 289.75,
    petrol_capacity NUMERIC(12,2)  DEFAULT 25000,
    diesel_capacity NUMERIC(12,2)  DEFAULT 25000,
    price_history   JSONB          DEFAULT '[]'::jsonb,
    mobil_history   JSONB          DEFAULT '[]'::jsonb,
    mobil_arrivals  JSONB          DEFAULT '[]'::jsonb,
    mobil_sales     JSONB          DEFAULT '[]'::jsonb,
    created_at      TIMESTAMPTZ    DEFAULT NOW(),
    updated_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── TANKS ─────────────────────────────────────────────────────
CREATE TABLE public.tanks (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    fuel_type       TEXT           NOT NULL,        -- 'Petrol', 'Diesel', 'Car Mobil', 'Open Mobil'
    name            TEXT,                           -- Optional display name
    current_stock   NUMERIC(12,2)  DEFAULT 0,
    capacity        NUMERIC(12,2)  DEFAULT 25000,
    last_updated    TIMESTAMPTZ    DEFAULT NOW(),
    UNIQUE (user_id, fuel_type)
);

-- ── CUSTOMERS ─────────────────────────────────────────────────
CREATE TABLE public.customers (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    sr_no           INTEGER,
    name            TEXT           NOT NULL,
    phone           TEXT,
    category        TEXT,                           -- 'Owner', 'LEG', 'Individual', etc.
    account_type    TEXT           NOT NULL DEFAULT 'credit',
    balance         NUMERIC(14,2)  DEFAULT 0,
    credit_limit    NUMERIC(14,2),
    initial_credit  NUMERIC(14,2)  DEFAULT 0,
    is_expense_also BOOLEAN        DEFAULT FALSE,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── TRANSACTIONS ──────────────────────────────────────────────
CREATE TABLE public.transactions (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    customer_id     INTEGER        REFERENCES public.customers(id) ON DELETE SET NULL,
    tank_id         INTEGER        REFERENCES public.tanks(id)     ON DELETE SET NULL,
    transaction_type TEXT          NOT NULL,         -- 'Credit', 'Debit', 'Expense'
    amount          NUMERIC(14,2)  NOT NULL DEFAULT 0,
    liters          NUMERIC(12,2),
    unit_price      NUMERIC(10,2),
    description     TEXT,
    fuel_type       VARCHAR(50),
    payment_method  TEXT,
    payment_mode    TEXT,
    payment_month   VARCHAR(10),
    entry_month     TEXT,
    entry_method    VARCHAR(20),
    expense_type    VARCHAR(100),
    expense_account VARCHAR(50),
    charges         NUMERIC(14,2)  DEFAULT 0,
    reference_no    TEXT,
    cash_advance_id BIGINT,
    company_txn_id  BIGINT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── STOCK ENTRIES ─────────────────────────────────────────────
CREATE TABLE public.stock_entries (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    fuel_type       VARCHAR(20)    NOT NULL,
    liters          NUMERIC(12,2)  NOT NULL,
    price_per_liter NUMERIC(10,2)  NOT NULL,
    total_amount    NUMERIC(14,2)  NOT NULL,
    charges         NUMERIC(14,2)  DEFAULT 0,
    net_payable     NUMERIC(14,2),
    invoice_number  VARCHAR(50),
    truck_number    VARCHAR(50),
    supplier_name   VARCHAR(100),
    purchase_date   DATE           DEFAULT CURRENT_DATE,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── PRICE HISTORY ─────────────────────────────────────────────
CREATE TABLE public.price_history (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    fuel_type       VARCHAR(50),
    price           NUMERIC(10,2),
    effective_date  DATE           DEFAULT CURRENT_DATE,
    updated_by      VARCHAR(100),
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── DAILY REPORTS ─────────────────────────────────────────────
CREATE TABLE public.daily_reports (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    report_date     DATE           NOT NULL,
    petrol_opening  NUMERIC(12,2)  DEFAULT 0,
    petrol_closing  NUMERIC(12,2)  DEFAULT 0,
    diesel_opening  NUMERIC(12,2)  DEFAULT 0,
    diesel_closing  NUMERIC(12,2)  DEFAULT 0,
    total_sales     NUMERIC(14,2)  DEFAULT 0,
    total_cash      NUMERIC(14,2)  DEFAULT 0,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── CASH ADVANCES ─────────────────────────────────────────────
CREATE TABLE public.cash_advances (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    customer_id     INTEGER        NOT NULL REFERENCES public.customers(id) ON DELETE CASCADE,
    amount          NUMERIC(14,2)  NOT NULL,
    reason          TEXT           NOT NULL,
    advance_date    DATE           NOT NULL DEFAULT CURRENT_DATE,
    status          TEXT           NOT NULL DEFAULT 'open',   -- 'open', 'settled'
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW(),
    updated_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── EXPENSE CATEGORIES ────────────────────────────────────────
CREATE TABLE public.expense_categories (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    name            TEXT           NOT NULL,
    icon            TEXT,
    is_default      BOOLEAN        DEFAULT FALSE,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── EXPENSE TYPES ─────────────────────────────────────────────
CREATE TABLE public.expense_types (
    id              BIGSERIAL PRIMARY KEY,
    name            TEXT           NOT NULL
);


-- ================================================================
-- STEP 4: SHOPS & RENT
-- ================================================================

-- ── SHOPS ─────────────────────────────────────────────────────
CREATE TABLE public.shops (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    shop_name       TEXT           NOT NULL,
    tenant_name     TEXT           NOT NULL,
    phone           TEXT,
    monthly_rent    NUMERIC(12,2)  NOT NULL,
    due_day         INTEGER        NOT NULL DEFAULT 1,
    start_date      DATE           NOT NULL,
    status          TEXT           NOT NULL DEFAULT 'active',  -- 'active', 'inactive'
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW(),
    updated_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── RENT PAYMENTS ─────────────────────────────────────────────
CREATE TABLE public.rent_payments (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    shop_id         BIGINT         NOT NULL REFERENCES public.shops(id) ON DELETE CASCADE,
    rent_month      INTEGER        NOT NULL,
    rent_year       INTEGER        NOT NULL,
    amount_due      NUMERIC(12,2)  NOT NULL,
    amount_paid     NUMERIC(12,2)  DEFAULT 0,
    due_date        DATE           NOT NULL,
    paid_date       DATE,
    payment_method  TEXT,
    status          TEXT           NOT NULL DEFAULT 'pending',  -- 'pending', 'paid', 'partial'
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW(),
    updated_at      TIMESTAMPTZ    DEFAULT NOW()
);


-- ================================================================
-- STEP 5: COMPANY / GO COMPANY TABLES
