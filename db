-- ================================================================
-- STEP 9: VIEW — Company Account Summary
-- ================================================================
CREATE OR REPLACE VIEW public.v_company_account_summary AS
SELECT
    ct.user_id,
    ct.company_id,
    'Go Company'                         AS company_name,
    COALESCE(SUM(CASE WHEN ct.direction='debit'  THEN ct.net_amount ELSE 0 END), 0) AS total_debit,
    COALESCE(SUM(CASE WHEN ct.direction='credit' THEN ct.net_amount ELSE 0 END), 0) AS total_credit,
    COALESCE(SUM(CASE WHEN ct.direction='debit'  THEN ct.net_amount ELSE 0 END), 0)
  - COALESCE(SUM(CASE WHEN ct.direction='credit' THEN ct.net_amount ELSE 0 END), 0) AS balance
FROM public.company_transactions ct
GROUP BY ct.user_id, ct.company_id;


