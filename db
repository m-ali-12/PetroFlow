-- ── MOBIL PRODUCTS ────────────────────────────────────────────
CREATE TABLE public.mobil_products (
    id              BIGSERIAL PRIMARY KEY,
    name            TEXT           NOT NULL,
    brand           TEXT,
    grade           TEXT,
    volume_ml       INTEGER,
    unit            TEXT           DEFAULT 'liter',
    category        TEXT           NOT NULL DEFAULT 'Car Mobil',  -- 'Car Mobil', 'Open Mobil'
    is_active       BOOLEAN        DEFAULT TRUE,
    sort_order      INTEGER        DEFAULT 0,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW(),
    updated_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL PRODUCT PRICES ──────────────────────────────────────
CREATE TABLE public.mobil_product_prices (
    id              BIGSERIAL PRIMARY KEY,
    product_id      BIGINT         NOT NULL REFERENCES public.mobil_products(id) ON DELETE CASCADE,
    sale_price      NUMERIC(12,2)  NOT NULL,
    purchase_price  NUMERIC(12,2),
    effective_date  DATE           NOT NULL DEFAULT CURRENT_DATE,
    changed_by      TEXT,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL STOCK ───────────────────────────────────────────────
CREATE TABLE public.mobil_stock (
    id              SERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    oil_type        TEXT           NOT NULL,   -- 'Car Mobil', 'Open Mobil'
    brand           TEXT,
    grade           TEXT,
    current_stock   NUMERIC(12,2)  DEFAULT 0,
    unit            TEXT           DEFAULT 'liter',
    last_updated    TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL ARRIVALS ────────────────────────────────────────────
CREATE TABLE public.mobil_arrivals (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    product_id      BIGINT         REFERENCES public.mobil_products(id) ON DELETE SET NULL,
    product_name    TEXT           NOT NULL,
    category        TEXT           NOT NULL,   -- 'Car Mobil', 'Open Mobil'
    supplier        TEXT,
    quantity        NUMERIC(10,2)  NOT NULL,
    rate            NUMERIC(10,2)  NOT NULL,
    total_cost      NUMERIC(14,2),
    arrival_date    DATE           NOT NULL DEFAULT CURRENT_DATE,
    invoice_no      TEXT,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL SALES ───────────────────────────────────────────────
CREATE TABLE public.mobil_sales (
    id              BIGSERIAL PRIMARY KEY,
    user_id         UUID REFERENCES auth.users(id) ON DELETE CASCADE,
    customer_id     INTEGER        REFERENCES public.customers(id) ON DELETE SET NULL,
    customer_name   TEXT,
    product_id      BIGINT         REFERENCES public.mobil_products(id) ON DELETE SET NULL,
    product_name    TEXT           NOT NULL,
    category        TEXT           NOT NULL,
    quantity        NUMERIC(10,2)  NOT NULL,
    rate            NUMERIC(10,2)  NOT NULL,
    total_amount    NUMERIC(14,2),
    payment_type    TEXT           DEFAULT 'cash',   -- 'cash', 'credit'
    sale_date       DATE           NOT NULL DEFAULT CURRENT_DATE,
    notes           TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL CUSTOMERS (legacy) ──────────────────────────────────
CREATE TABLE public.mobil_customers (
    id              SERIAL PRIMARY KEY,
    customer_name   TEXT           NOT NULL,
    phone           TEXT,
    address         TEXT,
    vehicle_type    TEXT,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);

-- ── MOBIL TRANSACTIONS (legacy) ───────────────────────────────
CREATE TABLE public.mobil_transactions (
    id              SERIAL PRIMARY KEY,
    customer_id     INTEGER        REFERENCES public.mobil_customers(id) ON DELETE SET NULL,
    stock_id        INTEGER,
    transaction_type TEXT          NOT NULL,
    payment_type    TEXT,
    description     TEXT,
    amount          NUMERIC(14,2)  DEFAULT 0,
    created_at      TIMESTAMPTZ    DEFAULT NOW()
);


