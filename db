    -- Create default settings
    INSERT INTO public.settings (user_id, petrol_price, diesel_price, petrol_capacity, diesel_capacity)
    VALUES (NEW.id, 276.50, 289.75, 25000, 25000);

    -- Create default expense categories
    INSERT INTO public.expense_categories (user_id, name, icon, is_default)
    VALUES
        (NEW.id, 'Staff Salary',     'bi-people',         true),
        (NEW.id, 'Electricity',      'bi-lightning',      true),
        (NEW.id, 'Maintenance',      'bi-tools',          true),
        (NEW.id, 'Fuel Purchase',    'bi-fuel-pump',      true),
        (NEW.id, 'Generator',        'bi-battery',        true),
        (NEW.id, 'Other',            'bi-three-dots',     true);

    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Trigger: new user signup pe auto-run
