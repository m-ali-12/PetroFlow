    txn_type        TEXT           NOT NULL,   -- 'stock_purchase', 'card_usage', 'repayment', 'cash_payment'
    amount          NUMERIC(14,2)  NOT NULL,
    direction       TEXT           NOT NULL,   -- 'debit', 'credit'
    charges         NUMERIC(14,2)  DEFAULT 0,
    net_amount      NUMERIC(14,2),
